<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CGF · CELL SPACE · FRACTAL LANGUAGE</title>
<style>
/* ── RESET ── */
*{box-sizing:border-box;margin:0;padding:0}
html,body{width:100%;min-height:100vh;background:#000208;color:#8aaccc;font-family:'Courier New',monospace;overflow-x:hidden}

/* ── SCAN LINE ── */
body::after{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.07) 3px,rgba(0,0,0,0.07) 4px);pointer-events:none;z-index:9999}

/* ── ROOT TOKENS ── */
:root{
  --bg:        #000208;
  --panel:     #00030f;
  --border:    rgba(40,100,200,0.14);
  --border2:   rgba(0,255,150,0.12);
  --border3:   rgba(250,150,0,0.14);
  --seq:       #00ff99;
  --amber:     #ffaa00;
  --violet:    #9966ff;
  --dim:       #223344;
  --dim2:      #334466;
  --text:      #8aaccc;
  --text2:     #5577aa;
  --mono:      'Courier New', monospace;
}

/* ── HEADER ── */
#header{
  padding:14px 18px 10px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
  position:sticky;top:0;z-index:50;
}
.h-row{display:flex;align-items:baseline;gap:12px;margin-bottom:8px;flex-wrap:wrap}
.h-title{font-size:15px;letter-spacing:0.25em;color:var(--seq);font-weight:normal}
.h-sub{font-size:9px;letter-spacing:0.2em;color:var(--dim2)}
.h-author{font-size:8px;letter-spacing:0.15em;color:var(--amber);opacity:0.7;margin-left:auto}
.chip-row{display:flex;gap:6px;flex-wrap:wrap}
.chip{
  background:rgba(0,255,150,0.04);
  border:1px solid rgba(0,255,150,0.12);
  border-radius:2px;
  padding:3px 8px;
  font-size:9px;letter-spacing:0.1em;color:var(--text2)
}
.chip b{color:var(--seq)}

/* ── AXIS LEGEND ── */
#axis-bar{
  display:flex;gap:16px;flex-wrap:wrap;
  padding:7px 18px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
}
.ax{font-size:8px;letter-spacing:0.15em;color:var(--dim2)}
.ax b{color:var(--text)}
.ax em{color:var(--amber);font-style:normal}

/* ── MAIN GRID ── */
#main{display:grid;grid-template-columns:1fr;gap:0}

/* ── CANVAS WRAP ── */
#canvas-wrap{
  position:relative;width:100%;height:340px;
  overflow:hidden;background:var(--bg);
  border-bottom:1px solid var(--border);
}
#c{display:block;width:100%;height:100%}
.overlay-label{
  position:absolute;font-size:8px;letter-spacing:0.15em;
  color:var(--dim2);pointer-events:none;font-family:var(--mono)
}
#hover-tag{
  display:none;position:absolute;
  background:rgba(0,3,15,0.92);
  border:1px solid var(--seq);
  border-radius:2px;padding:3px 8px;
  font-size:9px;letter-spacing:0.1em;color:var(--seq);
  pointer-events:none;font-family:var(--mono);
  box-shadow:0 0 8px rgba(0,255,150,0.15)
}

/* ── CONTROLS ── */
#controls{
  padding:10px 18px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
  display:flex;flex-direction:column;gap:8px
}
.ctrl-row{display:flex;align-items:center;gap:10px}
.ctrl-label{font-size:8px;letter-spacing:0.2em;color:var(--dim2);min-width:72px}
select{
  font-size:9px;flex:1;padding:5px 8px;
  background:var(--bg);
  border:1px solid var(--border);
  border-radius:2px;color:var(--text);
  font-family:var(--mono);letter-spacing:0.1em;
  outline:none;cursor:pointer
}
select:focus{border-color:var(--seq)}

/* ── CELL INFO ── */
#cell-info{
  padding:12px 18px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
  min-height:68px;
}
.ci-id{font-size:11px;letter-spacing:0.2em;color:var(--seq);margin-bottom:4px}
.ci-meta{font-size:9px;letter-spacing:0.1em;color:var(--text2);line-height:2}
.ci-triple{
  display:inline-block;margin-top:6px;
  font-size:10px;letter-spacing:0.1em;
  color:var(--amber);
  border:1px solid rgba(250,150,0,0.2);
  padding:3px 10px;border-radius:2px;
}

/* ── LANGUAGE ENGINE ── */
#lang-panel{
  border-bottom:1px solid var(--border2);
  background:var(--bg);
}
#lang-header{
  display:flex;align-items:center;gap:10px;
  padding:10px 18px;
  border-bottom:1px solid var(--border2);
  background:rgba(0,255,150,0.02);
}
.lang-title{font-size:8px;letter-spacing:0.25em;color:var(--seq)}
.lang-dot{width:6px;height:6px;border-radius:50%;background:var(--seq);animation:blink 1.4s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
.lang-status{font-size:8px;letter-spacing:0.15em;color:var(--dim2);margin-left:auto}

/* ── SEQUENCE STREAMS ── */
#seq-grid{
  display:grid;
  grid-template-columns:1fr;
  gap:0;
}
.seq-block{padding:10px 18px;border-bottom:1px solid var(--border)}
.seq-label{font-size:7px;letter-spacing:0.25em;color:var(--dim2);margin-bottom:6px}

/* DNA/RNA stream */
#seq-stream{
  font-size:10px;letter-spacing:0.18em;line-height:1.9;
  color:var(--seq);word-break:break-all;
  min-height:48px;
  font-family:var(--mono);
  white-space:pre-wrap;
}
#seq-stream .t-df{color:var(--seq)}
#seq-stream .t-om{color:var(--violet)}
#seq-stream .t-rh{color:var(--amber)}
#seq-stream .t-sp{color:var(--dim2)}
#seq-stream .t-bin{color:#226644}

/* Binary decode row */
#bin-stream{
  font-size:8px;letter-spacing:0.22em;line-height:2;
  color:#1a4433;word-break:break-all;
  min-height:32px;font-family:var(--mono);
  transition:color 0.3s;
}
#bin-stream.active{color:#0f6}

/* Codon table */
#codon-table{width:100%;border-collapse:collapse}
#codon-table td,#codon-table th{
  padding:4px 10px;font-size:8px;letter-spacing:0.1em;
  border:1px solid var(--border);text-align:left;
}
#codon-table th{color:var(--dim2);background:rgba(0,0,0,0.3)}
#codon-table td:first-child{color:var(--violet)}
#codon-table td:nth-child(2){color:var(--seq);font-family:var(--mono)}
#codon-table td:nth-child(3){color:var(--amber)}
#codon-table td:nth-child(4){color:var(--text2)}
.active-codon{background:rgba(0,255,150,0.06)!important}

/* ── METRIC DISPLAY ── */
#metric-panel{
  padding:12px 18px;
  border-bottom:1px solid var(--border);
  background:var(--panel);
}
.metric-row{display:flex;gap:0;border:1px solid var(--border)}
.metric-cell{
  flex:1;padding:8px 10px;
  border-right:1px solid var(--border);
  min-width:0;
}
.metric-cell:last-child{border-right:none}
.mc-key{font-size:7px;letter-spacing:0.2em;color:var(--dim2);margin-bottom:4px}
.mc-val{font-size:13px;color:var(--text);letter-spacing:0.05em}
.mc-val.green{color:var(--seq)}
.mc-val.amber{color:var(--amber)}
.mc-val.violet{color:var(--violet)}

/* ── COUSIN STRIP ── */
#cousin-panel{
  padding:10px 18px;
  border-bottom:1px solid var(--border);
  background:var(--bg);
}
.cousin-label{font-size:7px;letter-spacing:0.25em;color:var(--dim2);margin-bottom:8px}
#cousin-strip{display:flex;gap:6px;flex-wrap:wrap}
.cousin-chip{
  padding:4px 10px;
  background:rgba(153,102,255,0.05);
  border:1px solid rgba(153,102,255,0.18);
  border-radius:2px;
  font-size:8px;letter-spacing:0.1em;color:var(--violet);cursor:pointer;
  transition:all 0.15s;
}
.cousin-chip:hover{background:rgba(153,102,255,0.12);color:#fff}

/* ── FOOTER ── */
#footer{
  padding:10px 18px;
  background:var(--panel);
  display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px;
  border-top:1px solid var(--border);
}
.ft-txt{font-size:7px;letter-spacing:0.15em;color:var(--dim)}
.ft-txt b{color:var(--dim2)}
</style>
